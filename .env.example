# ============================================
# 🤖 INSTA TREND AI — Configuration
# ============================================
# 
# STEP 1: Copy this file → rename to .env
#         cp .env.example .env
#
# STEP 2: Fill in your keys below
#
# STEP 3: npm install && npm start
# ============================================


# --- REQUIRED KEYS ---

# Telegram Bot Token
# Get it from @BotFather on Telegram → send /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key  
# Get it from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# --- YOUR NICHE & CREATORS ---

# Your Instagram niche (be specific!)
# Examples: "fitness for working moms", "street food reviews", "tech gadgets under 5000", "minimal home decor"
MY_NICHE=fitness

# Creators you follow / want to learn from (comma separated)
# The bot will analyze their strategies and give you personalized tips
MY_FAVORITE_CREATORS=@viratian.club,@beerbiceps,@ranveerallahbadia

# Your target audience
# Examples: "18-25 year old Indian men interested in fitness", "women entrepreneurs in tier 2 cities"
MY_AUDIENCE=18-30 year old Indians interested in health and fitness

# Your content language
# Options: english, hindi, hinglish, tamil, telugu, etc.
MY_LANGUAGE=hinglish

# Your Instagram handle (optional — for personalized tips)
MY_INSTAGRAM=@your_handle