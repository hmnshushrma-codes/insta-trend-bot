# ============================================
# 🤖 INSTA TREND AI — Configuration
# ============================================
# 
# STEP 1: cp .env.example .env
# STEP 2: Fill in your 2 keys below
# STEP 3: npm install && npm start
#
# That's it! The bot will ask you everything 
# else (niche, creators, audience) via Telegram.
# ============================================

# Telegram Bot Token
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Anthropic API Key
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here